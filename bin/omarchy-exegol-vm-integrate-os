#!/bin/bash
set -euo pipefail

CONFIG_ROOT="${XDG_CONFIG_HOME:-$HOME/.config}"
PROJECT_ROOT="$CONFIG_ROOT/omarchy-exegol-vm"
MENU_TEMPLATE="${OMARCHY_EXEGOL_VM_DATA_DIR:-/usr/share/omarchy-exegol-vm}/omarchy-menu.sh"
HYPR_TEMPLATE="${OMARCHY_EXEGOL_VM_DATA_DIR:-/usr/share/omarchy-exegol-vm}/hypr/omarchy-exegol-vm.conf"
MENU_TARGET="$PROJECT_ROOT/menu.sh"
HYPR_TARGET_DIR="$PROJECT_ROOT/hypr"
HYPR_TARGET="$HYPR_TARGET_DIR/omarchy-exegol-vm.conf"
OMARCHY_MENU="$CONFIG_ROOT/omarchy/extensions/menu.sh"
HYPRLAND_CONF="$CONFIG_ROOT/hypr/hyprland.conf"
MENU_MARKER_BEGIN="# >>> omarchy-exegol-vm menu integration >>>"
MENU_MARKER_END="# <<< omarchy-exegol-vm menu integration <<<"
HYPR_MARKER_BEGIN="# >>> omarchy-exegol-vm hypr integration >>>"
HYPR_MARKER_END="# <<< omarchy-exegol-vm hypr integration <<<"

append_marker_block() {
  local file="$1"
  local begin="$2"
  local end="$3"
  local body="$4"

  mkdir -p "$(dirname "$file")"
  touch "$file"
  if grep -Fqx "$begin" "$file"; then
    return 0
  fi

  {
    printf '\n%s\n' "$begin"
    printf '%s\n' "$body"
    printf '%s\n' "$end"
  } >> "$file"
}

# When running from the repo checkout (dev mode), fall back to the local share/ dir
if [[ ! -f "$MENU_TEMPLATE" ]]; then
  SHARE_DIR="$(cd "$(dirname "$(readlink -f "$0")")/../share" && pwd)"
  MENU_TEMPLATE="$SHARE_DIR/omarchy-menu.sh"
  HYPR_TEMPLATE="$SHARE_DIR/hypr/omarchy-exegol-vm.conf"
fi

install -Dm644 "$MENU_TEMPLATE" "$MENU_TARGET"
install -Dm644 "$HYPR_TEMPLATE" "$HYPR_TARGET"

append_marker_block \
  "$OMARCHY_MENU" \
  "$MENU_MARKER_BEGIN" \
  "$MENU_MARKER_END" \
  "source \"$MENU_TARGET\""

append_marker_block \
  "$HYPRLAND_CONF" \
  "$HYPR_MARKER_BEGIN" \
  "$HYPR_MARKER_END" \
  "source = $HYPR_TARGET"

printf 'Installed Omarchy integration in %s\n' "$CONFIG_ROOT"
