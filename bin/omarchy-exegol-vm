#!/bin/bash
set -euo pipefail

CONFIG_ROOT="${XDG_CONFIG_HOME:-$HOME/.config}"
DATA_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}"
STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/omarchy-exegol-vm"
COMPOSE_FILE="$CONFIG_ROOT/exegol/docker-compose.yml"
EXEGOL_CONFIG_DIR="$CONFIG_ROOT/exegol"
EXEGOL_STORAGE="$HOME/.exegol"
CONTAINER_NAME="${OMARCHY_EXEGOL_VM_CONTAINER_NAME:-omarchy-exegol-vm}"
USER_APPLICATIONS_DIR="$DATA_ROOT/applications"
RUNTIME_DESKTOP_FILE="$USER_APPLICATIONS_DIR/omarchy-exegol-vm.desktop"
WORKSPACE_MAPPER_NAME="exegol-workspace"
WORKSPACE_MOUNT_POINT="$EXEGOL_STORAGE/workspace-mount"

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# Resolve scripts dir: pacman install (/usr/share/...) or dev checkout (../scripts/)
if [[ -d "/usr/share/omarchy-exegol-vm/scripts" ]]; then
  SCRIPTS_DIR="/usr/share/omarchy-exegol-vm/scripts"
elif [[ -d "$SCRIPT_DIR/../scripts" ]]; then
  SCRIPTS_DIR="$(cd "$SCRIPT_DIR/../scripts" && pwd)"
else
  echo "ERROR: Cannot find omarchy-exegol-vm scripts directory." >&2
  exit 1
fi

DEBUG_MODE=false
DEBUG_SUBCOMMAND=""
DEBUG_REPORT_DIR=""
DEBUG_STAGE="setup"
DEBUG_STATUS="pending"
DEBUG_MESSAGE=""
DEBUG_PRESERVED_ARTIFACTS=()

# ── Debug helpers (same pattern as kali-vm) ───────────────────────

record_preserved_artifact() {
  local artifact_path="$1"
  if [[ "$DEBUG_MODE" != true ]] || [[ -z "$artifact_path" ]]; then
    return 0
  fi
  DEBUG_PRESERVED_ARTIFACTS+=("$artifact_path")
}

ensure_debug_report_dir() {
  if [[ "$DEBUG_MODE" != true ]] || [[ -n "$DEBUG_REPORT_DIR" ]]; then
    return 0
  fi
  local timestamp
  timestamp=$(date -u +%Y%m%dT%H%M%SZ)
  DEBUG_REPORT_DIR="$STATE_ROOT/${DEBUG_SUBCOMMAND}-${timestamp}"
  mkdir -p "$DEBUG_REPORT_DIR"
}

write_debug_report() {
  if [[ "$DEBUG_MODE" != true ]]; then
    return 0
  fi
  ensure_debug_report_dir
  {
    printf 'subcommand: %s\n' "$DEBUG_SUBCOMMAND"
    printf 'debug: true\n'
    printf 'timestamp: %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf 'status: %s\n' "$DEBUG_STATUS"
    printf 'stage: %s\n' "$DEBUG_STAGE"
    printf 'message: %s\n' "${DEBUG_MESSAGE:-none}"
    printf 'report_dir: %s\n' "$DEBUG_REPORT_DIR"
    printf 'compose_file: %s\n' "$COMPOSE_FILE"
    printf 'config_dir: %s\n' "$EXEGOL_CONFIG_DIR"
    printf 'storage_dir: %s\n' "$EXEGOL_STORAGE"
    printf '\npreserved_artifacts:\n'
    if (( ${#DEBUG_PRESERVED_ARTIFACTS[@]} == 0 )); then
      printf '  (none)\n'
    else
      printf '  %s\n' "${DEBUG_PRESERVED_ARTIFACTS[@]}"
    fi
  } > "$DEBUG_REPORT_DIR/report.txt"
}

print_debug_summary() {
  if [[ "$DEBUG_MODE" != true ]]; then
    return 0
  fi
  echo "Debug report written to: $DEBUG_REPORT_DIR"
  if (( ${#DEBUG_PRESERVED_ARTIFACTS[@]} > 0 )); then
    echo "Preserved artifacts:"
    printf '  %s\n' "${DEBUG_PRESERVED_ARTIFACTS[@]}"
  fi
}

prepare_debug_run() {
  local subcommand="$1"
  DEBUG_MODE=true
  DEBUG_SUBCOMMAND="$subcommand"
  DEBUG_REPORT_DIR=""
  DEBUG_STAGE="setup"
  DEBUG_STATUS="running"
  DEBUG_MESSAGE=""
  DEBUG_PRESERVED_ARTIFACTS=()
  ensure_debug_report_dir
  echo "Debug mode enabled."
  echo "Reports will be written under: $DEBUG_REPORT_DIR"
}

capture_debug_sidecar() {
  local source_path="$1"
  local dest_name="$2"
  if [[ "$DEBUG_MODE" != true ]] || [[ ! -f "$source_path" ]]; then
    return 0
  fi
  ensure_debug_report_dir
  cp -f "$source_path" "$DEBUG_REPORT_DIR/$dest_name"
  record_preserved_artifact "$DEBUG_REPORT_DIR/$dest_name"
}

fail_install() {
  local stage="$1"
  local message="$2"
  DEBUG_STAGE="$stage"
  DEBUG_STATUS="failed"
  DEBUG_MESSAGE="$message"
  write_debug_report
  echo "ERROR: $message"
  print_debug_summary
  exit 1
}

parse_debug_flag() {
  local subcommand="$1"
  shift
  DEBUG_MODE=false
  if [[ $# -eq 0 ]]; then
    return 0
  fi
  case "$1" in
    --debug)
      if [[ $# -ne 1 ]]; then
        echo "Unknown option(s) for $subcommand: ${*:2}" >&2
        exit 1
      fi
      prepare_debug_run "$subcommand"
      ;;
    *)
      echo "Unknown option for $subcommand: $1" >&2
      exit 1
      ;;
  esac
}

# ── Dependency checks ─────────────────────────────────────────────

require_command() {
  local command_name="$1"
  local package_hint="${2:-$1}"
  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "Missing required command: $command_name"
    echo "Install the package that provides it: $package_hint"
    exit 1
  fi
}

require_compose() {
  if ! docker compose version >/dev/null 2>&1; then
    echo "docker compose is required."
    echo "Install Docker with the compose plugin and ensure the daemon is running."
    exit 1
  fi
}

docker_available() {
  command -v docker >/dev/null 2>&1
}

docker_compose_available() {
  docker_available && docker compose version >/dev/null 2>&1
}

notify_if_available() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$@"
  fi
}

check_common_dependencies() {
  require_command docker docker
  require_command gum gum
  require_command sudo sudo
  require_compose
}

check_install_dependencies() {
  check_common_dependencies
  require_command curl curl
  require_command remote-viewer virt-viewer
}

check_launch_dependencies() {
  check_common_dependencies
  require_command remote-viewer virt-viewer
}

check_remove_dependencies() {
  require_command gum gum
}

# ── Desktop entry helpers (same pattern as kali-vm) ───────────────

refresh_desktop_database() {
  if ! command -v update-desktop-database >/dev/null 2>&1; then
    return 0
  fi
  update-desktop-database "$USER_APPLICATIONS_DIR" >/dev/null 2>&1 || true
}

write_runtime_launcher() {
  mkdir -p "$USER_APPLICATIONS_DIR"
  cat > "$RUNTIME_DESKTOP_FILE" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=Exegol
Comment=Launch the Exegol offensive security VM
Exec=omarchy-exegol-vm launch
Icon=omarchy-exegol-vm
Terminal=false
Categories=System;Security;Utility;
Keywords=exegol;virtual machine;vm;security;pentest;
EOF
  refresh_desktop_database
}

remove_runtime_launcher() {
  rm -f "$RUNTIME_DESKTOP_FILE"
  refresh_desktop_database
}

# ── Managed state helpers ─────────────────────────────────────────

list_managed_state_paths() {
  printf '%s\n' \
    "$EXEGOL_CONFIG_DIR" \
    "$COMPOSE_FILE" \
    "$EXEGOL_STORAGE" \
    "$RUNTIME_DESKTOP_FILE"
}

list_existing_managed_state_paths() {
  local managed_path
  while IFS= read -r managed_path; do
    if [[ -e "$managed_path" ]]; then
      printf '%s\n' "$managed_path"
    fi
  done < <(list_managed_state_paths)
}

managed_state_exists() {
  local existing_state
  while IFS= read -r existing_state; do
    if [[ -n "$existing_state" ]]; then
      return 0
    fi
  done < <(list_existing_managed_state_paths)
  return 1
}

path_state_label() {
  local managed_path="$1"
  if [[ -e "$managed_path" ]]; then
    printf 'present'
  else
    printf 'not present'
  fi
}

print_install_existing_state_error() {
  local existing_state
  echo "Existing managed Exegol VM state detected."
  echo "'omarchy-exegol-vm install' only supports first-time setup."
  echo "Remove the existing VM before reinstalling: omarchy-exegol-vm remove"
  echo ""
  echo "Detected managed state:"
  while IFS= read -r existing_state; do
    printf '  %s\n' "$existing_state"
  done < <(list_existing_managed_state_paths)
}

print_remove_preview() {
  echo "Managed Exegol VM targets scheduled for deletion:"
  printf '  Config directory:  %s (%s)\n' "$EXEGOL_CONFIG_DIR" "$(path_state_label "$EXEGOL_CONFIG_DIR")"
  printf '  Compose file:      %s (%s)\n' "$COMPOSE_FILE" "$(path_state_label "$COMPOSE_FILE")"
  printf '  Storage directory: %s (%s)\n' "$EXEGOL_STORAGE" "$(path_state_label "$EXEGOL_STORAGE")"
  printf '  Runtime launcher:  %s (%s)\n' "$RUNTIME_DESKTOP_FILE" "$(path_state_label "$RUNTIME_DESKTOP_FILE")"
}

# ── Docker cleanup ────────────────────────────────────────────────

best_effort_remove_docker_artifacts() {
  if docker_compose_available; then
    docker compose -f "$COMPOSE_FILE" down 2>/dev/null || echo "Warning: Docker Compose shutdown failed during removal; continuing."
  elif docker_available; then
    echo "Skipping Docker Compose shutdown: docker compose unavailable."
  else
    echo "Skipping Docker cleanup: docker unavailable."
  fi

  if [[ "$DEBUG_MODE" = true ]]; then
    return 0
  fi

  if docker_available; then
    docker rmi qemux/qemu 2>/dev/null || true
  fi
}

# ── SPICE & QEMU helpers ─────────────────────────────────────────

exegol_qemu_arguments() {
  echo "-spice unix=on,addr=/storage/spice.sock,disable-ticketing=on -device qemu-xhci -device usb-tablet -device virtio-serial-pci -chardev spicevmc,id=vdagent,name=vdagent -device virtserialport,chardev=vdagent,name=com.redhat.spice.0"
}

ensure_exegol_runtime_config() {
  # Write start.sh hook if missing
  if [[ ! -f "$EXEGOL_CONFIG_DIR/start.sh" ]]; then
    mkdir -p "$EXEGOL_CONFIG_DIR"
    cat << 'EOF' | tee "$EXEGOL_CONFIG_DIR/start.sh" > /dev/null
#!/bin/bash
set -e
if qemu-system-x86_64 -spice help >/dev/null 2>&1; then
  exit 0
fi
echo "Installing QEMU SPICE module..."
DEBIAN_FRONTEND=noninteractive apt-get -qq update
DEBIAN_FRONTEND=noninteractive apt-get -qq --no-install-recommends -y install qemu-system-modules-spice > /dev/null
EOF
    chmod +x "$EXEGOL_CONFIG_DIR/start.sh"
  fi

  # Ensure ARGUMENTS is up-to-date in compose
  if [[ -f "$COMPOSE_FILE" ]]; then
    local QEMU_ARGUMENTS
    QEMU_ARGUMENTS=$(exegol_qemu_arguments)
    # Only update if the compose no longer has boot media lines (post-finalize)
    if ! grep -q 'seed.img' "$COMPOSE_FILE"; then
      sed -i "s|^\([[:space:]]*ARGUMENTS:\).*|\1 \"$QEMU_ARGUMENTS\"|" "$COMPOSE_FILE"
    fi
  fi
}

graceful_shutdown() {
  # Send ACPI shutdown via QEMU monitor
  if docker inspect --format='{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null | grep -q running; then
    echo "Sending ACPI shutdown to guest..."
    docker exec "$CONTAINER_NAME" bash -c 'echo "system_powerdown" | nc -q1 localhost 7100' 2>/dev/null || true
    local WAIT=0
    while docker inspect --format='{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null | grep -q running; do
      sleep 2
      WAIT=$((WAIT + 1))
      if (( WAIT > 30 )); then
        echo "Guest did not shut down within 60s, forcing stop..."
        break
      fi
    done
  fi
  docker compose -f "$COMPOSE_FILE" down 2>/dev/null || true
  rm -f "$EXEGOL_STORAGE/spice.sock"
}

# ── Workspace helpers ─────────────────────────────────────────────

workspace_is_mounted() {
  mountpoint -q "$WORKSPACE_MOUNT_POINT" 2>/dev/null
}

umount_workspace_if_mounted() {
  if workspace_is_mounted; then
    echo "Unmounting workspace..."
    bash "$SCRIPTS_DIR/workspace-mount.sh" umount 2>/dev/null || true
  fi
}

# ── Commands ──────────────────────────────────────────────────────

install_exegol() {
  parse_debug_flag install "$@"

  if managed_state_exists; then
    print_install_existing_state_error
    exit 1
  fi

  check_install_dependencies

  # Check KVM
  if [[ ! -e /dev/kvm ]]; then
    gum style \
      --border normal \
      --padding "1 2" \
      --margin "1" \
      "KVM virtualization not available!" \
      "" \
      "Please enable virtualization in BIOS or run:" \
      "  sudo modprobe kvm-intel  # for Intel CPUs" \
      "  sudo modprobe kvm-amd    # for AMD CPUs"
    exit 1
  fi

  DEBUG_STAGE="install"
  bash "$SCRIPTS_DIR/install.sh"

  write_runtime_launcher

  if [[ "$DEBUG_MODE" = true ]]; then
    DEBUG_STATUS="succeeded"
    DEBUG_MESSAGE="Install completed successfully."
    write_debug_report
    print_debug_summary
  fi
}

launch_exegol() {
  check_launch_dependencies
  KEEP_ALIVE=false
  if [[ "${1:-}" = "--keep-alive" ]] || [[ "${1:-}" = "-k" ]]; then
    KEEP_ALIVE=true
  fi

  if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "Exegol VM not configured. Please run: omarchy-exegol-vm install"
    exit 1
  fi

  ensure_exegol_runtime_config

  CONTAINER_STATUS=$(docker inspect --format='{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || true)

  local SPICE_SOCK="$EXEGOL_STORAGE/spice.sock"

  if [[ "$CONTAINER_STATUS" != "running" ]]; then
    echo "Starting Exegol VM..."
    notify_if_available "Starting Exegol VM" "This can take 15-30 seconds" -t 15000

    rm -f "$SPICE_SOCK"

    if ! docker compose -f "$COMPOSE_FILE" up -d 2>&1; then
      echo "Failed to start Exegol VM!"
      notify_if_available -u critical "Exegol VM" "Failed to start"
      exit 1
    fi
  fi

  echo "Waiting for Exegol VM to be ready..."
  local WAIT_COUNT=0
  until [[ -S "$SPICE_SOCK" ]]; do
    sleep 2
    WAIT_COUNT=$((WAIT_COUNT + 1))
    if (( WAIT_COUNT > 60 )); then
      echo "Timeout: Exegol VM SPICE not ready within 2 minutes"
      notify_if_available -u critical "Exegol VM" "SPICE not ready"
      exit 1
    fi
  done
  docker exec "$CONTAINER_NAME" chmod 666 /storage/spice.sock

  if [[ -t 1 ]]; then
    if [[ $KEEP_ALIVE = "true" ]]; then
      LIFECYCLE="VM will keep running after viewer closes
To stop: omarchy-exegol-vm stop"
    else
      LIFECYCLE="VM will auto-stop when viewer closes"
    fi
    gum style \
      --border normal \
      --padding "1 2" \
      --margin "1" \
      --align center \
      "Connecting to Exegol VM" \
      "" \
      "$LIFECYCLE" \
      "" \
      "Workspace: $(bash "$SCRIPTS_DIR/workspace-mount.sh" status 2>/dev/null || echo 'unknown')"
  fi

  remote-viewer "spice+unix://$SPICE_SOCK" -t "Exegol VM" --auto-resize=always

  if [[ $KEEP_ALIVE = "false" ]]; then
    echo ""
    echo "SPICE session closed. Stopping Exegol VM..."
    umount_workspace_if_mounted
    graceful_shutdown
    echo "Exegol VM stopped."
  else
    echo ""
    echo "SPICE session closed. Exegol VM is still running."
    echo "To stop it: omarchy-exegol-vm stop"
  fi
}

stop_exegol() {
  check_common_dependencies
  if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "Exegol VM not configured."
    exit 1
  fi

  echo "Stopping Exegol VM..."
  umount_workspace_if_mounted
  graceful_shutdown
  echo "Exegol VM stopped."
}

status_exegol() {
  check_common_dependencies
  if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "Exegol VM not configured."
    echo "To set up: omarchy-exegol-vm install"
    exit 1
  fi

  CONTAINER_STATUS=$(docker inspect --format='{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null || true)

  local ws_status
  ws_status=$(bash "$SCRIPTS_DIR/workspace-mount.sh" status 2>/dev/null || echo "unknown")

  if [[ -z "$CONTAINER_STATUS" ]]; then
    echo "Exegol VM container not found."
    echo "To start: omarchy-exegol-vm launch"
  elif [[ "$CONTAINER_STATUS" = "running" ]]; then
    gum style \
      --border normal \
      --padding "1 2" \
      --margin "1" \
      --align left \
      "Exegol VM Status: RUNNING" \
      "" \
      "$ws_status" \
      "" \
      "To connect: omarchy-exegol-vm launch" \
      "To stop:    omarchy-exegol-vm stop"
  else
    echo "Exegol VM is stopped (status: $CONTAINER_STATUS)"
    echo "$ws_status"
    echo "To start: omarchy-exegol-vm launch"
  fi
}

workspace_cmd() {
  local action="${1:-status}"
  bash "$SCRIPTS_DIR/workspace-mount.sh" "$action"
}

finalize_exegol() {
  # Remove ISO and seed boot media from compose after initial cloud-init setup
  if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "Exegol VM not configured."
    exit 1
  fi

  echo "Finalizing Exegol VM setup..."
  echo "Removing boot media (ISO + cloud-init seed) from compose configuration."

  # Rewrite ARGUMENTS without the -drive lines for ISO and seed
  local QEMU_ARGUMENTS
  QEMU_ARGUMENTS=$(exegol_qemu_arguments)
  sed -i "s|^\([[:space:]]*ARGUMENTS:\).*|\1 \"$QEMU_ARGUMENTS\"|" "$COMPOSE_FILE"

  # Remove the ISO and seed files
  rm -f "$EXEGOL_STORAGE/ubuntu.iso"
  rm -f "$EXEGOL_STORAGE/seed.img"

  echo "Finalization complete."
  echo "The VM will now boot directly from the installed QCOW2."
  echo "Launch with: omarchy-exegol-vm launch"
}

remove_exegol() {
  parse_debug_flag remove "$@"
  check_remove_dependencies

  print_remove_preview

  if ! gum confirm --default=false "Remove Exegol VM and delete all associated data?"; then
    echo "Removal cancelled."
    exit 1
  fi

  echo "Removing Exegol VM..."
  DEBUG_STAGE="remove"

  # Unmount workspace if active
  umount_workspace_if_mounted

  best_effort_remove_docker_artifacts

  rm -rf "$EXEGOL_CONFIG_DIR"
  rm -rf "$EXEGOL_STORAGE"
  remove_runtime_launcher

  if [[ "$DEBUG_MODE" = true ]]; then
    DEBUG_STATUS="succeeded"
    DEBUG_MESSAGE="Remove completed with debug retention enabled."
    write_debug_report
    print_debug_summary
  fi

  echo ""
  echo "Exegol VM removal completed!"
}

show_usage() {
  echo "Usage: omarchy-exegol-vm [command] [options]"
  echo ""
  echo "Commands:"
  echo "  install [--debug]    Install and configure Exegol VM (first-time setup only)"
  echo "  remove [--debug]     Remove Exegol VM and all its data"
  echo "  launch [options]     Start Exegol VM (if needed) and connect via SPICE"
  echo "                       Options:"
  echo "                         --keep-alive, -k   Keep VM running after viewer closes"
  echo "  stop                 Stop the running Exegol VM"
  echo "  status               Show current VM status"
  echo "  workspace [action]   Manage encrypted workspace (mount|umount|status)"
  echo "  finalize             Remove boot media after initial cloud-init setup"
  echo "  help                 Show this help message"
  echo ""
  echo "Examples:"
  echo "  omarchy-exegol-vm install           # Set up Exegol VM for first time"
  echo "  omarchy-exegol-vm install --debug   # Keep debug evidence"
  echo "  omarchy-exegol-vm launch            # Connect to VM (auto-stop on exit)"
  echo "  omarchy-exegol-vm launch -k         # Connect to VM (keep running)"
  echo "  omarchy-exegol-vm workspace mount   # Mount encrypted workspace"
  echo "  omarchy-exegol-vm workspace umount  # Lock workspace"
  echo "  omarchy-exegol-vm finalize          # Remove ISO after first setup"
  echo "  omarchy-exegol-vm stop              # Shut down the VM"
  echo "  omarchy-exegol-vm remove --debug    # Remove with debug retention"
  echo ""
  echo "Security:"
  echo "  The VM uses 3 layers of encryption:"
  echo "    1. LUKS host (Omarchy, already active)"
  echo "    2. Ephemeral mode (tmpfs overlay on /home inside VM)"
  echo "    3. workspace.luks (separate encrypted container for persistent data)"
  echo ""
  echo "Optional Omarchy integration:"
  echo "  omarchy-exegol-vm-integrate-os"
  echo "  omarchy-exegol-vm-unintegrate-os"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  case "${1:-}" in
    install)
      shift
      install_exegol "$@"
      ;;
    remove)
      shift
      remove_exegol "$@"
      ;;
    launch|start)
      launch_exegol "${2:-}"
      ;;
    stop|down)
      stop_exegol
      ;;
    status)
      status_exegol
      ;;
    workspace)
      workspace_cmd "${2:-status}"
      ;;
    finalize)
      finalize_exegol
      ;;
    help|--help|-h|"")
      show_usage
      ;;
    *)
      echo "Unknown command: $1" >&2
      echo "" >&2
      show_usage >&2
      exit 1
      ;;
  esac
fi
